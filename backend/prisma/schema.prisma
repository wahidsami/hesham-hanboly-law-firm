generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AdminUser {
  id           String         @id @default(cuid())
  username     String         @unique
  passwordHash String
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  sessions     AdminSession[]
}

model AdminSession {
  id          String     @id @default(cuid())
  token       String     @unique
  expiresAt   DateTime
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  adminUserId String
  adminUser   AdminUser  @relation(fields: [adminUserId], references: [id], onDelete: Cascade)
}

model Asset {
  id           String    @id @default(cuid())
  key          String    @unique
  url          String
  mimeType     String
  size         Int
  originalName  String
  altAr        String?
  altEn        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model HeroSlide {
  id            String   @id
  badgeAr       String
  badgeEn       String
  badgeIcon     String
  titleArLine1  String
  titleEnLine1  String
  titleArLine2  String
  titleEnLine2  String
  descriptionAr String
  descriptionEn String
  ctaTextAr     String
  ctaTextEn     String
  actionType    String
  actionParam   String?
  image         String
  imageAltAr    String
  imageAltEn    String
  highlightBox  Json?
  order         Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}


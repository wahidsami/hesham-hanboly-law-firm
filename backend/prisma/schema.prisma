model CmsPage {
  id          String   @id
  titleAr     String
  titleEn     String
  slug        String   @unique
  status      String
  navVisible  Boolean  @default(false)
  blocksCount Int      @default(0)
  author      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model NavItem {
  id             String   @id
  pageId         String   @unique
  labelAr        String
  labelEn        String
  url            String
  desktopVisible Boolean  @default(true)
  mobileVisible  Boolean  @default(true)
  order          Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model CmsRevision {
  id        String   @id
  pageId    String
  label     String
  status    String
  blocks    Json
  author    String
  note      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Article {
  id           String   @id @default(cuid())
  slug         String   @unique
  titleAr      String
  titleEn      String
  excerptAr    String
  excerptEn    String
  categoryAr   String
  categoryEn   String
  authorAr     String
  authorEn     String
  date         String
  readTimeAr   String
  readTimeEn   String
  bodyAr       String
  bodyEn       String
  imageUrl     String
  published    Boolean  @default(true)
  order        Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model PracticeArea {
  id             String   @id @default(cuid())
  slug           String   @unique
  categorySlug   String
  titleAr        String
  titleEn        String
  categoryAr     String
  categoryEn     String
  shortDescAr    String
  shortDescEn    String
  aboutAr        Json
  aboutEn        Json
  features       Json
  processSteps   Json
  useCases       Json
  faq            Json
  imageUrl       String?
  published      Boolean  @default(true)
  order          Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}
